{
  "expo": {
    "name": "Memora",
    "slug": "Memora",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "memora",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#01696f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jotape.memora.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Memora needs camera access to capture text from books and notes for flashcard generation.",
        "NSPhotoLibraryUsageDescription": "Memora needs photo library access to select images for text extraction."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#01696f"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.jotape.memora.app",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#01696f"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Memora needs camera access to capture text from books and notes."
        }
      ]
    ]
  }
}
