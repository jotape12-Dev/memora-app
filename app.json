{
  "expo": {
    "name": "Memora",
    "slug": "Memora",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "memora",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jotape.memora.app",
      "buildNumber": "2",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "O Memora usa a câmera para fotografar textos e gerar flashcards automaticamente.",
        "NSPhotoLibraryUsageDescription": "O Memora acessa a galeria para importar imagens de texto para gerar flashcards.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#01696f"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.jotape.memora.app",
      "versionCode": 2,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#f7f6f2",
          "dark": {
            "backgroundColor": "#171614"
          },
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#01696f"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "O Memora usa a câmera para fotografar textos e gerar flashcards automaticamente."
        }
      ]
    ]
  }
}
